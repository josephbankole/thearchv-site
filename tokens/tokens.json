{
  "$meta": {
    "name": "The ARCHV — Brand Tokens",
    "source": "fifa.archv/thearchv-site/src/style.css (:root) — reconciled with public/content.css",
    "note": "Locked palette. Gold is a capped accent (<= 2 elements per viewport). Display type runs light."
  },
  "color": {
    "navy": { "value": "#0c2a3e", "type": "color", "description": "Base background" },
    "navy-deep": { "value": "#071c2b", "type": "color", "description": "Deepest panel / overlay base" },
    "navy-soft": { "value": "#133a52", "type": "color", "description": "Raised surface (cards)" },
    "cream": { "value": "#f2ead3", "type": "color", "description": "Primary text / on-navy" },
    "cream-dim": { "value": "rgba(242, 234, 211, 0.6)", "type": "color", "description": "Secondary text" },
    "cream-faint": { "value": "rgba(242, 234, 211, 0.28)", "type": "color", "description": "Hairlines, borders, tertiary text" },
    "gold": { "value": "#c9a14a", "type": "color", "description": "Capped accent — links, key marks, primary button" },
    "gold-soft": { "value": "rgba(201, 161, 74, 0.5)", "type": "color", "description": "Accent border / focus ring" },
    "pitch": { "value": "#2e6b3a", "type": "color", "description": "Confirm / done state (pitch green)" },
    "error": { "value": "#d9785f", "type": "color", "description": "Form error text" },
    "error-border": { "value": "#b5563f", "type": "color", "description": "Invalid field border" }
  },
  "font": {
    "family": {
      "serif": { "value": "'Fraunces Variable', 'Fraunces', Georgia, 'Times New Roman', serif", "type": "fontFamily", "description": "Display / headings — runs light" },
      "grotesque": { "value": "'Inter Tight Variable', 'Inter Tight', system-ui, -apple-system, sans-serif", "type": "fontFamily", "description": "Body, UI, labels" }
    },
    "weight": {
      "light": { "value": 300, "type": "fontWeight", "description": "Manifesto / lede serif" },
      "display": { "value": 340, "type": "fontWeight", "description": "Default display weight (intentionally light)" },
      "display-mid": { "value": 360, "type": "fontWeight" },
      "regular": { "value": 400, "type": "fontWeight" },
      "medium": { "value": 500, "type": "fontWeight", "description": "Eyebrows, buttons, UI" },
      "semibold": { "value": 600, "type": "fontWeight", "description": "Gold button, article headings" },
      "bold": { "value": 700, "type": "fontWeight", "description": "Follow-bar emphasis only" }
    },
    "size": {
      "display": { "value": "clamp(2.8rem, 8vw, 5rem)", "type": "fontSize" },
      "h2": { "value": "clamp(2rem, 5.2vw, 4.4rem)", "type": "fontSize" },
      "h3": { "value": "1.375rem", "type": "fontSize" },
      "body": { "value": "clamp(1.0625rem, 1.4vw, 1.1875rem)", "type": "fontSize" },
      "label": { "value": "0.72rem", "type": "fontSize", "description": "Uppercase, letter-spaced eyebrow/label" }
    },
    "lineHeight": {
      "body": { "value": 1.6, "type": "number" },
      "display": { "value": 0.98, "type": "number", "description": "Tight hero leading" }
    },
    "letterSpacing": {
      "label": { "value": "0.22em", "type": "dimension", "description": "Uppercase labels / eyebrows" },
      "display": { "value": "-0.035em", "type": "dimension", "description": "Hero negative tracking" }
    }
  },
  "layout": {
    "maxWidth": { "value": "1280px", "type": "dimension", "description": "App content max width" },
    "measure": { "value": "46rem", "type": "dimension", "description": "Article reading measure (content pages)" },
    "gutter": { "value": "clamp(1.25rem, 5vw, 5rem)", "type": "dimension", "description": "Page inline padding" }
  },
  "radius": {
    "sm": { "value": "2px", "type": "dimension", "description": "Default — buttons, frames, tags" },
    "md": { "value": "3px", "type": "dimension", "description": "Daily-digest cards" },
    "lg": { "value": "10px", "type": "dimension", "description": "Legend cards" },
    "article": { "value": "0.6rem", "type": "dimension", "description": "Article figures / CTA blocks" }
  },
  "motion": {
    "ease": { "value": "cubic-bezier(0.22, 1, 0.36, 1)", "type": "cubicBezier", "description": "Default ease for transforms" },
    "ease-out-expo": { "value": "cubic-bezier(0.16, 1, 0.3, 1)", "type": "cubicBezier", "description": "Sharp entrance" }
  }
}
